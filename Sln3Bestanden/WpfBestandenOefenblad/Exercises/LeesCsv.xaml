<Page x:Class="WpfBestandenOefenblad.Exercises.LeesCsv"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:WpfBestandenOefenblad.Exercises"
      mc:Ignorable="d"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="LeesCsv">

    <Grid Background="#eeeeee">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="320"/>
        </Grid.RowDefinitions>
        <Frame x:Name="fraAssignment" Grid.Row="0" Grid.Column="0" />
        <Border Background="White" Grid.Row="1">
            <!-- XAML VAN DE OEFENING -->
            <Grid Margin="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"></RowDefinition>
                    <RowDefinition Height="*"></RowDefinition>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Button x:Name="btnLaad"
                        Grid.Row="0"
                        Content="Laad verkoopcijfers"
                        HorizontalAlignment="Left"
                        Padding="8.4"
                        Margin="0,0,0,5"
                        Click="btnLaad_Click"/>

                <ListBox x:Name="LstVerkoop"
                         Grid.Row="1"
                         Margin="0,0,0,5"/>

                <TextBlock x:Name="tblTotaal"
                           Grid.Row="2"
                           FontWeight="Bold"
                           Margin="0,5,0,0"/>


            </Grid>
        </Border>
    </Grid>
</Page>
