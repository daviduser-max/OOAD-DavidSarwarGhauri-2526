<Page x:Class="WPFDokter.PatientenPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Patiënten">

    <Grid Background="#F5F7FA" Margin="20">
        <StackPanel>
            <TextBlock Text="Patiënten"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="#2C3E50"
                       Margin="0,0,0,15"/>

            <TextBlock Text="Hier komt het overzicht van patiënten (contact-cards en CRUD)."
                       TextWrapping="Wrap"
                       Foreground="#7F8C8D"
                       Margin="0,0,0,10"/>

            <TextBlock x:Name="lblFoutmelding"
                       Foreground="#E74C3C"
                       TextWrapping="Wrap"
                       Margin="0,0,0,10"/>
        </StackPanel>
    </Grid>
</Page>
