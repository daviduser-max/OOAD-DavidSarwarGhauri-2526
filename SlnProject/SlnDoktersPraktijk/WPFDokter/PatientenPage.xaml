<Page x:Class="WPFDokter.PatientenPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Patiëntenbeheer - Doktersportaal">

    <Grid Background="#F5F7FA">
        <Grid Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Pagina Header -->
            <TextBlock Grid.Row="0" 
                       x:Name="lblPaginaTitel" 
                       Text="Patiëntenbeheer"
                       FontSize="26"
                       FontWeight="Bold"
                       Foreground="#1F3B5B"
                       Margin="0,0,0,20"/>

            <!-- Inhoudsgebied -->
            <Grid Grid.Row="1">
                
                <!-- 1. OVERZICHT PANEL -->
                <Grid x:Name="pnlOverzicht" Visibility="Visible">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Zoeken & Toevoegen Kaart -->
                    <Border Grid.Row="0" 
                            Background="White"
                            CornerRadius="12"
                            Padding="20"
                            Margin="0,0,0,20"
                            BorderBrush="#E2E8F0"
                            BorderThickness="1">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="8" Color="#E2E8F0" Direction="270" ShadowDepth="2" Opacity="0.4"/>
                        </Border.Effect>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="280"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" 
                                       Text="Zoek patiënt:"
                                       VerticalAlignment="Center"
                                       FontWeight="SemiBold"
                                       Foreground="#334155"
                                       Margin="0,0,12,0"
                                       FontSize="14"/>

                            <TextBox Grid.Column="1" 
                                     x:Name="txtZoeken"
                                     Padding="10"
                                     FontSize="14"
                                     VerticalAlignment="Center"
                                     BorderThickness="1"
                                     BorderBrush="#CBD5E1">
                                <TextBox.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="6"/>
                                    </Style>
                                </TextBox.Resources>
                            </TextBox>

                            <Button Grid.Column="2" 
                                    x:Name="btnZoeken"
                                    Content="Zoeken"
                                    Click="BtnZoeken_Click"
                                    Background="#3498DB"
                                    Foreground="White"
                                    FontWeight="Bold"
                                    FontSize="14"
                                    Padding="18,10"
                                    Margin="10,0,0,0"
                                    VerticalAlignment="Center"
                                    Cursor="Hand">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="6"/>
                                    </Style>
                                </Button.Resources>
                            </Button>

                            <Button Grid.Column="4" 
                                    x:Name="btnNieuw"
                                    Content="+ Nieuwe Patiënt"
                                    Click="BtnNieuw_Click"
                                    Background="#2ECC71"
                                    Foreground="White"
                                    FontWeight="Bold"
                                    FontSize="14"
                                    Padding="18,10"
                                    VerticalAlignment="Center"
                                    Cursor="Hand">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="6"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Dynamische patiënten kaarten -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <WrapPanel x:Name="wpPatienten" Margin="-10,0"/>
                    </ScrollViewer>
                </Grid>

                <!-- 2. DETAILS PANEL -->
                <Grid x:Name="pnlDetails" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Terug knop -->
                    <Button Grid.Row="0" 
                            Content="← Terug naar overzicht"
                            Click="BtnTerug_Click"
                            HorizontalAlignment="Left"
                            Background="White"
                            Foreground="#1F3B5B"
                            BorderBrush="#CBD5E1"
                            BorderThickness="1"
                            FontWeight="SemiBold"
                            Padding="15,8"
                            Margin="0,0,0,20"
                            Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <!-- Details fiche -->
                    <Border Grid.Row="1" 
                            Background="White"
                            CornerRadius="12"
                            Padding="30"
                            BorderBrush="#E2E8F0"
                            BorderThickness="1">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="8" Color="#E2E8F0" Direction="270" ShadowDepth="2" Opacity="0.4"/>
                        </Border.Effect>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Ronde profielfoto met schaduw -->
                            <StackPanel Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Top">
                                <Border CornerRadius="60" 
                                        Width="120" 
                                        Height="120" 
                                        BorderBrush="#E2E8F0" 
                                        BorderThickness="2" 
                                        ClipToBounds="True">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="5" Color="#E2E8F0" Direction="270" ShadowDepth="1" Opacity="0.5"/>
                                    </Border.Effect>
                                    <Image x:Name="imgDetFoto" Stretch="UniformToFill"/>
                                </Border>
                            </StackPanel>

                            <!-- Persoonsgegevens -->
                            <StackPanel Grid.Column="1" Margin="25,0,0,0">
                                <TextBlock x:Name="txtDetNaam" 
                                           Text="[Naam]"
                                           FontSize="24" 
                                           FontWeight="Bold" 
                                           Foreground="#1F3B5B" 
                                           Margin="0,0,0,20"/>
                                
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="35"/>
                                        <RowDefinition Height="35"/>
                                        <RowDefinition Height="35"/>
                                        <RowDefinition Height="35"/>
                                        <RowDefinition Height="35"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Geslacht:" FontWeight="SemiBold" Foreground="#64748B" VerticalAlignment="Center" FontSize="14"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="txtDetGeslacht" FontSize="14" Foreground="#334155" VerticalAlignment="Center"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Geboortedatum:" FontWeight="SemiBold" Foreground="#64748B" VerticalAlignment="Center" FontSize="14"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="txtDetGeboortedatum" FontSize="14" Foreground="#334155" VerticalAlignment="Center"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="E-mailadres:" FontWeight="SemiBold" Foreground="#64748B" VerticalAlignment="Center" FontSize="14"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" x:Name="txtDetEmail" FontSize="14" Foreground="#334155" VerticalAlignment="Center"/>

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="GSM-nummer:" FontWeight="SemiBold" Foreground="#64748B" VerticalAlignment="Center" FontSize="14"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" x:Name="txtDetGsm" FontSize="14" Foreground="#334155" VerticalAlignment="Center"/>

                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Notificatievoorkeur:" FontWeight="SemiBold" Foreground="#64748B" VerticalAlignment="Center" FontSize="14"/>
                                    <TextBlock Grid.Row="4" Grid.Column="1" x:Name="txtDetNotificatie" FontSize="14" Foreground="#334155" VerticalAlignment="Center"/>
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <!-- 3. BEWERKEN / TOEVOEGEN PANEL -->
                <Grid x:Name="pnlBewerken" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Terug knop -->
                    <Button Grid.Row="0" 
                            Content="← Terug naar overzicht"
                            Click="BtnTerug_Click"
                            HorizontalAlignment="Left"
                            Background="White"
                            Foreground="#1F3B5B"
                            BorderBrush="#CBD5E1"
                            BorderThickness="1"
                            FontWeight="SemiBold"
                            Padding="15,8"
                            Margin="0,0,0,20"
                            Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <!-- Formulier Fiche -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <Border Background="White" 
                                CornerRadius="12" 
                                Padding="30"
                                BorderBrush="#E2E8F0"
                                BorderThickness="1">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8" Color="#E2E8F0" Direction="270" ShadowDepth="2" Opacity="0.4"/>
                            </Border.Effect>
                            
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="200"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Linker kolom: Foto kiezen -->
                                <StackPanel Grid.Column="0" HorizontalAlignment="Center" Margin="0,0,15,0">
                                    <Border CornerRadius="60" 
                                            Width="120" 
                                            Height="120" 
                                            BorderBrush="#E2E8F0" 
                                            BorderThickness="2" 
                                            ClipToBounds="True"
                                            Margin="0,0,0,15">
                                        <Image x:Name="imgEditFoto" Stretch="UniformToFill"/>
                                    </Border>
                                    
                                    <Button x:Name="btnUploadFoto"
                                            Content="Kies foto..."
                                            Click="BtnUploadFoto_Click"
                                            Margin="0,0,0,8"
                                            Padding="10,6"
                                            Background="White"
                                            BorderBrush="#CBD5E1"
                                            BorderThickness="1"
                                            FontWeight="SemiBold"
                                            Cursor="Hand">
                                        <Button.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="4"/>
                                            </Style>
                                        </Button.Resources>
                                    </Button>
                                    
                                    <Button x:Name="btnVerwijderFoto"
                                            Content="Verwijder foto"
                                            Click="BtnVerwijderFoto_Click"
                                            Padding="10,6"
                                            Background="#FFF5F5"
                                            BorderBrush="#FEB2B2"
                                            BorderThickness="1"
                                            Foreground="#E53E3E"
                                            FontWeight="SemiBold"
                                            Cursor="Hand">
                                        <Button.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="4"/>
                                            </Style>
                                        </Button.Resources>
                                    </Button>
                                </StackPanel>

                                <!-- Rechter kolom: Formulier velden -->
                                <StackPanel Grid.Column="1" Margin="20,0,0,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="130"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- Voornaam -->
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Voornaam:" FontWeight="SemiBold" Foreground="#334155" VerticalAlignment="Center" Margin="0,0,0,12" FontSize="14"/>
                                        <TextBox Grid.Row="0" Grid.Column="1" x:Name="txtEditVoornaam" Padding="8" FontSize="14" Margin="0,0,0,12" BorderBrush="#CBD5E1" BorderThickness="1">
                                            <TextBox.Resources>
                                                <Style TargetType="Border">
                                                    <Setter Property="CornerRadius" Value="4"/>
                                                </Style>
                                            </TextBox.Resources>
                                        </TextBox>

                                        <!-- Achternaam -->
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Familienaam:" FontWeight="SemiBold" Foreground="#334155" VerticalAlignment="Center" Margin="0,0,0,12" FontSize="14"/>
                                        <TextBox Grid.Row="1" Grid.Column="1" x:Name="txtEditAchternaam" Padding="8" FontSize="14" Margin="0,0,0,12" BorderBrush="#CBD5E1" BorderThickness="1">
                                            <TextBox.Resources>
                                                <Style TargetType="Border">
                                                    <Setter Property="CornerRadius" Value="4"/>
                                                </Style>
                                            </TextBox.Resources>
                                        </TextBox>

                                        <!-- E-mail -->
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="E-mailadres:" FontWeight="SemiBold" Foreground="#334155" VerticalAlignment="Center" Margin="0,0,0,12" FontSize="14"/>
                                        <TextBox Grid.Row="2" Grid.Column="1" x:Name="txtEditEmail" Padding="8" FontSize="14" Margin="0,0,0,12" BorderBrush="#CBD5E1" BorderThickness="1">
                                            <TextBox.Resources>
                                                <Style TargetType="Border">
                                                    <Setter Property="CornerRadius" Value="4"/>
                                                </Style>
                                            </TextBox.Resources>
                                        </TextBox>

                                        <!-- Wachtwoord -->
                                        <TextBlock Grid.Row="3" Grid.Column="0" x:Name="lblWachtwoordTitel" Text="Wachtwoord:" FontWeight="SemiBold" Foreground="#334155" VerticalAlignment="Center" Margin="0,0,0,12" FontSize="14"/>
                                        <TextBox Grid.Row="3" Grid.Column="1" x:Name="txtEditWachtwoord" Padding="8" FontSize="14" Margin="0,0,0,12" BorderBrush="#CBD5E1" BorderThickness="1">
                                            <TextBox.Resources>
                                                <Style TargetType="Border">
                                                    <Setter Property="CornerRadius" Value="4"/>
                                                </Style>
                                            </TextBox.Resources>
                                        </TextBox>

                                        <!-- GSM -->
                                        <TextBlock Grid.Row="4" Grid.Column="0" Text="GSM-nummer:" FontWeight="SemiBold" Foreground="#334155" VerticalAlignment="Center" Margin="0,0,0,12" FontSize="14"/>
                                        <TextBox Grid.Row="4" Grid.Column="1" x:Name="txtEditGsm" Padding="8" FontSize="14" Margin="0,0,0,12" BorderBrush="#CBD5E1" BorderThickness="1">
                                            <TextBox.Resources>
                                                <Style TargetType="Border">
                                                    <Setter Property="CornerRadius" Value="4"/>
                                                </Style>
                                            </TextBox.Resources>
                                        </TextBox>

                                        <!-- Geslacht -->
                                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Geslacht:" FontWeight="SemiBold" Foreground="#334155" VerticalAlignment="Center" Margin="0,0,0,12" FontSize="14"/>
                                        <StackPanel Grid.Row="5" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,12" VerticalAlignment="Center">
                                            <RadioButton x:Name="radMan" Content="Man" Margin="0,0,20,0" IsChecked="True" FontSize="14"/>
                                            <RadioButton x:Name="radVrouw" Content="Vrouw" FontSize="14"/>
                                        </StackPanel>

                                        <!-- Geboortedatum -->
                                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Geboortedatum:" FontWeight="SemiBold" Foreground="#334155" VerticalAlignment="Center" Margin="0,0,0,12" FontSize="14"/>
                                        <DatePicker Grid.Row="6" Grid.Column="1" x:Name="dpEditGeboortedatum" Padding="6" Margin="0,0,0,12" FontSize="14"/>

                                        <!-- Notificaties -->
                                        <TextBlock Grid.Row="7" Grid.Column="0" Text="Notificaties:" FontWeight="SemiBold" Foreground="#334155" VerticalAlignment="Center" Margin="0,0,0,20" FontSize="14"/>
                                        <ComboBox Grid.Row="7" Grid.Column="1" x:Name="cmbEditNotificaties" Padding="8" FontSize="14" Margin="0,0,0,20">
                                            <ComboBoxItem Content="Geen"/>
                                            <ComboBoxItem Content="E-mail"/>
                                            <ComboBoxItem Content="Sms"/>
                                            <ComboBoxItem Content="Beide (E-mail &amp; Sms)"/>
                                        </ComboBox>
                                    </Grid>

                                    <!-- Opslaan knop -->
                                    <Button x:Name="btnOpslaan"
                                            Content="Opslaan"
                                            Click="BtnOpslaan_Click"
                                            Background="#2ECC71"
                                            Foreground="White"
                                            FontWeight="Bold"
                                            FontSize="15"
                                            Padding="25,12"
                                            HorizontalAlignment="Right"
                                            Cursor="Hand">
                                        <Button.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="6"/>
                                            </Style>
                                        </Button.Resources>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </ScrollViewer>
                </Grid>
            </Grid>

            <!-- Fout- en feedbackmeldingen onderaan -->
            <TextBlock Grid.Row="2"
                       x:Name="lblFoutmelding"
                       Foreground="#E74C3C"
                       FontWeight="SemiBold"
                       Margin="0,15,0,0"
                       FontSize="13"
                       TextWrapping="Wrap"/>
        </Grid>
    </Grid>
</Page>

