<Page x:Class="WPFDokter.PatientenPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Patiëntenbeheer">

    <Grid Background="#F5F7FA">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

        <!-- Pagina Titel -->
        <TextBlock Grid.Row="0" x:Name="lblPaginaTitel" Text="Patiëntenbeheer"
                   FontSize="24"
                   FontWeight="Bold"
                   Foreground="#2C3E50"
                   Margin="0,0,0,15"/>

        <!-- Inhoudsgebied -->
        <Grid Grid.Row="1">
            
            <!-- 1. OVERZICHT PANEL -->
            <Grid x:Name="pnlOverzicht" Visibility="Visible">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Zoeken & Toevoegen -->
                <Grid Grid.Row="0" Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="250"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Zoeken:"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold"
                               Foreground="#34495E"
                               Margin="0,0,10,0"
                               FontSize="14"/>

                    <TextBox Grid.Column="1" x:Name="txtZoeken"
                             Padding="8"
                             FontSize="14"
                             VerticalAlignment="Center"/>

                    <Button Grid.Column="2" x:Name="btnZoeken"
                            Content="Zoeken"
                            Click="BtnZoeken_Click"
                            Background="#3498DB"
                            Foreground="White"
                            FontWeight="Bold"
                            Padding="15,8"
                            Margin="10,0,0,0"
                            VerticalAlignment="Center"/>

                    <Button Grid.Column="4" x:Name="btnNieuw"
                            Content="+ Nieuwe Patiënt"
                            Click="BtnNieuw_Click"
                            Background="#2ECC71"
                            Foreground="White"
                            FontWeight="Bold"
                            Padding="15,8"
                            VerticalAlignment="Center"/>
                </Grid>

                <!-- Dynamische patiënten kaarten -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <WrapPanel x:Name="wpPatienten" Margin="0,5"/>
                </ScrollViewer>
            </Grid>

            <!-- 2. DETAILS PANEL -->
            <Grid x:Name="pnlDetails" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Back button -->
                <Button Grid.Row="0" Content="← Terug naar overzicht"
                        Click="BtnTerug_Click"
                        HorizontalAlignment="Left"
                        Padding="10,5"
                        Margin="0,0,0,20"/>

                <!-- Details info -->
                <Grid Grid.Row="1" Background="White" Margin="0,0,0,10">
                    <Border BorderBrush="#BDC3C7" BorderThickness="1" Padding="20" CornerRadius="8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Image Grid.Column="0" x:Name="imgDetFoto"
                                   Width="120" Height="120"
                                   VerticalAlignment="Top"
                                   HorizontalAlignment="Left"
                                   Stretch="UniformToFill"/>

                            <StackPanel Grid.Column="1" Margin="20,0,0,0">
                                <TextBlock x:Name="txtDetNaam" FontSize="22" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,15"/>
                                
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="30"/>
                                        <RowDefinition Height="30"/>
                                        <RowDefinition Height="30"/>
                                        <RowDefinition Height="30"/>
                                        <RowDefinition Height="30"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Geslacht:" FontWeight="SemiBold" Foreground="#7F8C8D"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="txtDetGeslacht" FontSize="14"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Geboortedatum:" FontWeight="SemiBold" Foreground="#7F8C8D"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="txtDetGeboortedatum" FontSize="14"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="E-mailadres:" FontWeight="SemiBold" Foreground="#7F8C8D"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" x:Name="txtDetEmail" FontSize="14"/>

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="GSM-nummer:" FontWeight="SemiBold" Foreground="#7F8C8D"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" x:Name="txtDetGsm" FontSize="14"/>

                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Notificatie voorkeur:" FontWeight="SemiBold" Foreground="#7F8C8D"/>
                                    <TextBlock Grid.Row="4" Grid.Column="1" x:Name="txtDetNotificatie" FontSize="14"/>
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <!-- 3. BEWERKEN / TOEVOEGEN PANEL -->
            <Grid x:Name="pnlBewerken" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Back button -->
                <Button Grid.Row="0" Content="← Terug naar overzicht"
                        Click="BtnTerug_Click"
                        HorizontalAlignment="Left"
                        Padding="10,5"
                        Margin="0,0,0,20"/>

                <!-- Form -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <Border Grid.Row="1" Background="White" BorderBrush="#BDC3C7" BorderThickness="1" Padding="20" CornerRadius="8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Linker kolom: Foto kiezen -->
                            <StackPanel Grid.Column="0" HorizontalAlignment="Center" Margin="0,0,10,0">
                                <Image x:Name="imgEditFoto"
                                       Width="120" Height="120"
                                       Stretch="UniformToFill"/>
                                <Button x:Name="btnUploadFoto"
                                        Content="Kies foto..."
                                        Click="BtnUploadFoto_Click"
                                        Margin="0,10,0,0"
                                        Padding="5"/>
                                <Button x:Name="btnVerwijderFoto"
                                        Content="Verwijder foto"
                                        Click="BtnVerwijderFoto_Click"
                                        Margin="0,5,0,0"
                                        Padding="5"
                                        Background="#E74C3C"
                                        Foreground="White"/>
                            </StackPanel>

                            <!-- Rechter kolom: Formulier velden -->
                            <StackPanel Grid.Column="1" Margin="20,0,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Voornaam -->
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Voornaam:" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,0,10"/>
                                    <TextBox Grid.Row="0" Grid.Column="1" x:Name="txtEditVoornaam" Padding="6" FontSize="14" Margin="0,0,0,10"/>

                                    <!-- Achternaam -->
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Familienaam:" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,0,10"/>
                                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="txtEditAchternaam" Padding="6" FontSize="14" Margin="0,0,0,10"/>

                                    <!-- E-mail -->
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="E-mailadres:" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,0,10"/>
                                    <TextBox Grid.Row="2" Grid.Column="1" x:Name="txtEditEmail" Padding="6" FontSize="14" Margin="0,0,0,10"/>

                                    <!-- Wachtwoord (Enkel bij nieuwe patiënt, of optioneel bij wijzigen) -->
                                    <TextBlock Grid.Row="3" Grid.Column="0" x:Name="lblWachtwoordTitel" Text="Wachtwoord:" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,0,10"/>
                                    <TextBox Grid.Row="3" Grid.Column="1" x:Name="txtEditWachtwoord" Padding="6" FontSize="14" Margin="0,0,0,10"/>

                                    <!-- GSM -->
                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="GSM-nummer:" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,0,10"/>
                                    <TextBox Grid.Row="4" Grid.Column="1" x:Name="txtEditGsm" Padding="6" FontSize="14" Margin="0,0,0,10"/>

                                    <!-- Geslacht -->
                                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Geslacht:" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,0,10"/>
                                    <StackPanel Grid.Row="5" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,10" VerticalAlignment="Center">
                                        <RadioButton x:Name="radMan" Content="Man" Margin="0,0,20,0" IsChecked="True"/>
                                        <RadioButton x:Name="radVrouw" Content="Vrouw"/>
                                    </StackPanel>

                                    <!-- Geboortedatum -->
                                    <TextBlock Grid.Row="6" Grid.Column="0" Text="Geboortedatum:" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,0,10"/>
                                    <DatePicker Grid.Row="6" Grid.Column="1" x:Name="dpEditGeboortedatum" Padding="6" FontSize="14" Margin="0,0,0,10"/>

                                    <!-- Notificaties -->
                                    <TextBlock Grid.Row="7" Grid.Column="0" Text="Notificaties:" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,0,20"/>
                                    <ComboBox Grid.Row="7" Grid.Column="1" x:Name="cmbEditNotificaties" Padding="6" FontSize="14" Margin="0,0,0,20">
                                        <ComboBoxItem Content="Geen"/>
                                        <ComboBoxItem Content="E-mail"/>
                                        <ComboBoxItem Content="Sms"/>
                                        <ComboBoxItem Content="Beide (E-mail &amp; Sms)"/>
                                    </ComboBox>
                                </Grid>

                                <Button x:Name="btnOpslaan"
                                        Content="Opslaan"
                                        Click="BtnOpslaan_Click"
                                        Background="#2ECC71"
                                        Foreground="White"
                                        FontWeight="Bold"
                                        FontSize="16"
                                        Padding="20,10"
                                        HorizontalAlignment="Right"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </ScrollViewer>
            </Grid>
        </Grid>

        <!-- Fout- en feedbackmeldingen onderaan -->
        <TextBlock Grid.Row="2"
                   x:Name="lblFoutmelding"
                   Foreground="#E74C3C"
                   FontWeight="SemiBold"
                   Margin="0,10,0,0"
                   TextWrapping="Wrap"/>
        </Grid>
    </Grid>
</Page>
