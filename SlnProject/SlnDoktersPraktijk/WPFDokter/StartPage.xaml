<Page x:Class="WPFDokter.StartPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Startpagina - Doktersportaal">

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#F0F4F8" Offset="0"/>
                <GradientStop Color="#E8EEF4" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="50,40">

                <!-- Hero kaart -->
                <Border CornerRadius="18"
                        Padding="40,35"
                        Margin="0,0,0,28">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#0F2645" Offset="0"/>
                            <GradientStop Color="#1B4F72" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="20" Color="#0F2645" Direction="270" ShadowDepth="5" Opacity="0.3"/>
                    </Border.Effect>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Welkom bij"
                                       FontSize="15"
                                       Foreground="#90BDE0"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8"/>
                            <TextBlock Text="Medisch Beheerportaal"
                                       FontSize="34"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       Margin="0,0,0,14"/>
                            <TextBlock Text="Beheer uw patiënten en afspraken efficiënt via het linkermenu. Meld u eerst aan om toegang te krijgen tot alle functies."
                                       FontSize="14"
                                       Foreground="#B8D4E8"
                                       TextWrapping="Wrap"
                                       MaxWidth="450"
                                       LineHeight="22"/>
                        </StackPanel>

                        <Border Grid.Column="1"
                                Width="90" Height="90"
                                CornerRadius="20"
                                VerticalAlignment="Center"
                                Margin="30,0,0,0">
                            <Border.Background>
                                <SolidColorBrush Color="#FFFFFF" Opacity="0.1"/>
                            </Border.Background>
                            <TextBlock Text="🏥" FontSize="48"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Feature kaarten rij -->
                <TextBlock Text="Beschikbare functies"
                           FontSize="17"
                           FontWeight="Bold"
                           Foreground="#1E293B"
                           Margin="0,0,0,16"/>

                <UniformGrid Columns="2" Margin="0,0,0,0">

                    <!-- Afspraken kaart -->
                    <Border Background="White"
                            CornerRadius="14"
                            Padding="25,22"
                            Margin="0,0,12,0"
                            BorderBrush="#E2E8F0"
                            BorderThickness="1">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="10" Color="#CBD5E1" Direction="270" ShadowDepth="2" Opacity="0.35"/>
                        </Border.Effect>
                        <StackPanel>
                            <Border Width="44" Height="44" CornerRadius="12"
                                    HorizontalAlignment="Left" Margin="0,0,0,14">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#EBF8FF" Offset="0"/>
                                        <GradientStop Color="#BEE3F8" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="📅" FontSize="22"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Afspraken Overzicht"
                                       FontWeight="Bold"
                                       Foreground="#0F2645"
                                       FontSize="15"
                                       Margin="0,0,0,8"/>
                            <TextBlock Text="Bekijk en beheer uw afspraken per dag. Consultatieredenen inzien en toekomstige afspraken annuleren."
                                       Foreground="#64748B"
                                       FontSize="13"
                                       TextWrapping="Wrap"
                                       LineHeight="20"/>
                        </StackPanel>
                    </Border>

                    <!-- Patiënten kaart -->
                    <Border Background="White"
                            CornerRadius="14"
                            Padding="25,22"
                            BorderBrush="#E2E8F0"
                            BorderThickness="1">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="10" Color="#CBD5E1" Direction="270" ShadowDepth="2" Opacity="0.35"/>
                        </Border.Effect>
                        <StackPanel>
                            <Border Width="44" Height="44" CornerRadius="12"
                                    HorizontalAlignment="Left" Margin="0,0,0,14">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#F0FFF4" Offset="0"/>
                                        <GradientStop Color="#C6F6D5" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="👥" FontSize="22"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Patiënten Beheer"
                                       FontWeight="Bold"
                                       Foreground="#0F2645"
                                       FontSize="15"
                                       Margin="0,0,0,8"/>
                            <TextBlock Text="Raadpleeg de volledige patiëntenlijst, zoek op naam, voeg nieuwe patiënten toe of wijzig bestaande gegevens."
                                       Foreground="#64748B"
                                       FontSize="13"
                                       TextWrapping="Wrap"
                                       LineHeight="20"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- Onderstebalk: aanmelden tip -->
                <Border Background="#FFFBEB"
                        BorderBrush="#FDE68A"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="18,12"
                        Margin="0,24,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="💡" FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Text="Meld u aan via 'Inloggen' in het linkermenu om toegang te krijgen tot alle beveiligde functies."
                                   FontSize="13"
                                   Foreground="#92400E"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
