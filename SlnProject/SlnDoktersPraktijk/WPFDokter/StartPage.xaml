<Page x:Class="WPFDokter.StartPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Start">

    <Grid Background="#F5F7FA" Margin="30">
        <StackPanel VerticalAlignment="Center" MaxWidth="600">
            <TextBlock Text="Welkom bij de doktersapplicatie"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="#2C3E50"
                       Margin="0,0,0,20"/>

            <TextBlock TextWrapping="Wrap"
                       FontSize="14"
                       Foreground="#34495E"
                       LineHeight="22">
                Met deze applicatie kunt u als dokter:
                <LineBreak/><LineBreak/>
                • uw afspraken per dag bekijken en annuleren;
                <LineBreak/>
                • uw patiënten beheren (overzicht, details, toevoegen, wijzigen en verwijderen).
                <LineBreak/><LineBreak/>
                Log in via het menu links om te starten.
            </TextBlock>
        </StackPanel>
    </Grid>
</Page>
