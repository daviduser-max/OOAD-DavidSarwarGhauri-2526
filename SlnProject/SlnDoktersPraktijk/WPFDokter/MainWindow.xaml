<Window x:Class="WPFDokter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="Dokterspraktijk - Dokter"
        Height="600"
        Width="1000"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Linker navigatie -->
        <Border Grid.Column="0" Background="#2C3E50" Padding="10">
            <StackPanel>
                <TextBlock Text="Menu"
                           Foreground="White"
                           FontSize="18"
                           FontWeight="Bold"
                           Margin="0,0,0,20"/>

                <Button x:Name="btnStart"
                        Content="Start"
                        Margin="0,0,0,8"
                        Padding="8"
                        Click="BtnStart_Click"/>

                <Button x:Name="btnLogin"
                        Content="Login"
                        Margin="0,0,0,8"
                        Padding="8"
                        Click="BtnLogin_Click"/>

                <Button x:Name="btnAfspraken"
                        Content="Afspraken"
                        Margin="0,0,0,8"
                        Padding="8"
                        Visibility="Collapsed"
                        Click="BtnAfspraken_Click"/>

                <Button x:Name="btnPatienten"
                        Content="Patiënten"
                        Margin="0,0,0,8"
                        Padding="8"
                        Visibility="Collapsed"
                        Click="BtnPatienten_Click"/>

                <Button x:Name="btnUitloggen"
                        Content="Uitloggen"
                        Margin="0,20,0,0"
                        Padding="8"
                        Visibility="Collapsed"
                        Click="BtnUitloggen_Click"/>
            </StackPanel>
        </Border>

        <!-- Rechter inhoud -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Profiel rechtsboven (na login) -->
            <Border Grid.Row="0"
                    Background="#ECF0F1"
                    Padding="15"
                    x:Name="pnlHeader"
                    Visibility="Collapsed">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock x:Name="txtDokterNaam"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="#2C3E50"
                               VerticalAlignment="Center"
                               Margin="0,0,15,0"/>
                    <Image x:Name="imgProfielfoto"
                           Width="50"
                           Height="50"
                           Stretch="UniformToFill"/>
                </StackPanel>
            </Border>

            <Frame x:Name="mainFrame"
                   Grid.Row="1"
                   NavigationUIVisibility="Hidden"/>
        </Grid>
    </Grid>
</Window>
