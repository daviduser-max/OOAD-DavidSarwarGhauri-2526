<Page x:Class="WPFDokter.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Inloggen - Doktersportaal">

    <Grid>
        <!-- Gradient achtergrond -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0F2645" Offset="0"/>
                <GradientStop Color="#1A3A5C" Offset="0.5"/>
                <GradientStop Color="#1B4F72" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Login kaart gecentreerd -->
        <Border Background="White"
                CornerRadius="16"
                Padding="40,35"
                Width="400"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect BlurRadius="30" Color="#000000" Direction="270" ShadowDepth="8" Opacity="0.25"/>
            </Border.Effect>

            <StackPanel>
                <!-- Icoon / logo boven titel -->
                <Border Width="56" Height="56"
                        CornerRadius="14"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,18">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#2E86C1" Offset="0"/>
                            <GradientStop Color="#1A5276" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <TextBlock Text="🏥" FontSize="26" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <TextBlock Text="Doktersportaal"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="#0F2645"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,6"/>

                <TextBlock Text="Meld u aan om verder te gaan"
                           FontSize="13"
                           Foreground="#64748B"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,28"
                           TextAlignment="Center"/>

                <!-- Scheidingslijn -->
                <Border Height="1" Background="#F1F5F9" Margin="0,0,0,24"/>

                <!-- E-mail veld -->
                <TextBlock Text="E-mailadres"
                           FontWeight="SemiBold"
                           Foreground="#1E293B"
                           Margin="0,0,0,6"
                           FontSize="13"/>
                <Border BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="8" Margin="0,0,0,16">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="BorderBrush" Value="#3498DB"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBox x:Name="txtEmail"
                             Padding="12,10"
                             FontSize="14"
                             BorderThickness="0"
                             Background="Transparent"
                             Text="alexandre@dokterspraktijk.be"
                             Foreground="#1E293B"/>
                </Border>

                <!-- Wachtwoord veld -->
                <TextBlock Text="Wachtwoord"
                           FontWeight="SemiBold"
                           Foreground="#1E293B"
                           Margin="0,0,0,6"
                           FontSize="13"/>
                <Border BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="8" Margin="0,0,0,24">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="BorderBrush" Value="#3498DB"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <PasswordBox x:Name="pwdWachtwoord"
                                 Padding="12,10"
                                 FontSize="14"
                                 BorderThickness="0"
                                 Background="Transparent"/>
                </Border>

                <!-- Inloggen knop -->
                <Button x:Name="btnInloggen"
                        Content="Aanmelden"
                        FontWeight="Bold"
                        FontSize="15"
                        Padding="0,13"
                        Cursor="Hand"
                        Click="BtnInloggen_Click"
                        BorderThickness="0"
                        Foreground="White">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#2E86C1" Offset="0"/>
                            <GradientStop Color="#1A5276" Offset="1"/>
                        </LinearGradientBrush>
                    </Button.Background>
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="btnBorder"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="8"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="btnBorder" Property="Opacity" Value="0.85"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="btnBorder" Property="Opacity" Value="0.7"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Foutmelding -->
                <Border x:Name="foutBorder"
                        Background="#FEF2F2"
                        BorderBrush="#FECACA"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12,10"
                        Margin="0,14,0,0"
                        Visibility="Collapsed">
                    <TextBlock x:Name="lblFoutmelding"
                               Foreground="#DC2626"
                               TextWrapping="Wrap"
                               FontSize="13"
                               TextAlignment="Center"/>
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</Page>
