<Page x:Class="WPFPatiënt.ProfielPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="800"
      Title="Mijn Profiel">

    <Grid Background="#F5F7FA">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid Margin="25">
                <Border Background="White" 
                        CornerRadius="12" 
                        Padding="30"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="8" Color="#E2E8F0" Direction="270" ShadowDepth="2" Opacity="0.4"/>
                    </Border.Effect>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <!-- Linker kolom: Foto -->
                            <ColumnDefinition Width="180"/>
                            <!-- Rechter kolom: Formulier -->
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Foto Upload / Wijzigen -->
                        <StackPanel Grid.Column="0" HorizontalAlignment="Center" Margin="0,0,20,0">
                            <TextBlock Text="Profielfoto" 
                                       FontWeight="Bold" 
                                       Foreground="#1F3B5B" 
                                       FontSize="16" 
                                       Margin="0,0,0,15"
                                       HorizontalAlignment="Center"/>
                            
                            <Border CornerRadius="8" BorderThickness="1" BorderBrush="#E2E8F0" Width="140" Height="140" Background="#F8FAFC">
                                <Image x:Name="imgProfielfoto" Stretch="UniformToFill"/>
                            </Border>

                            <Button x:Name="btnUploadFoto" 
                                    Content="Kies foto..." 
                                    Margin="0,15,0,0" 
                                    Padding="10,6" 
                                    Background="#3498DB" 
                                    Foreground="White" 
                                    FontWeight="Bold" 
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Click="BtnUploadFoto_Click">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="4"/>
                                    </Style>
                                </Button.Resources>
                            </Button>

                            <Button x:Name="btnVerwijderFoto" 
                                    Content="Verwijder" 
                                    Margin="0,8,0,0" 
                                    Padding="10,6" 
                                    Background="#E74C3C" 
                                    Foreground="White" 
                                    FontWeight="Bold" 
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Click="BtnVerwijderFoto_Click">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="4"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </StackPanel>

                        <!-- Formulier Velden -->
                        <StackPanel Grid.Column="1" Margin="20,0,0,0">
                            <TextBlock Text="Persoonlijke Gegevens" 
                                       FontWeight="Bold" 
                                       Foreground="#1F3B5B" 
                                       FontSize="18" 
                                       Margin="0,0,0,20"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Voornaam -->
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Voornaam:" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="#334155" Margin="0,0,0,12"/>
                                <TextBox Grid.Row="0" Grid.Column="1" x:Name="txtVoornaam" Padding="8" FontSize="14" Margin="0,0,0,12" BorderThickness="1" BorderBrush="#CBD5E1">
                                    <TextBox.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="4"/>
                                        </Style>
                                    </TextBox.Resources>
                                </TextBox>

                                <!-- Achternaam -->
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Achternaam:" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="#334155" Margin="0,0,0,12"/>
                                <TextBox Grid.Row="1" Grid.Column="1" x:Name="txtAchternaam" Padding="8" FontSize="14" Margin="0,0,0,12" BorderThickness="1" BorderBrush="#CBD5E1">
                                    <TextBox.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="4"/>
                                        </Style>
                                    </TextBox.Resources>
                                </TextBox>

                                <!-- Geboortedatum -->
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Geboortedatum:" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="#334155" Margin="0,0,0,12"/>
                                <DatePicker Grid.Row="2" Grid.Column="1" x:Name="dpGeboortedatum" Padding="8" Margin="0,0,0,12" BorderThickness="1" BorderBrush="#CBD5E1"/>

                                <!-- Geslacht -->
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Geslacht:" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="#334155" Margin="0,0,0,12"/>
                                <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,12" VerticalAlignment="Center">
                                    <RadioButton x:Name="radMan" Content="Man" Margin="0,0,20,0" FontSize="14" IsChecked="True"/>
                                    <RadioButton x:Name="radVrouw" Content="Vrouw" FontSize="14"/>
                                </StackPanel>

                                <!-- E-mailadres -->
                                <TextBlock Grid.Row="4" Grid.Column="0" Text="E-mailadres:" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="#334155" Margin="0,0,0,12"/>
                                <TextBox Grid.Row="4" Grid.Column="1" x:Name="txtEmail" Padding="8" FontSize="14" Margin="0,0,0,12" BorderThickness="1" BorderBrush="#CBD5E1">
                                    <TextBox.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="4"/>
                                        </Style>
                                    </TextBox.Resources>
                                </TextBox>

                                <!-- GSM-nummer -->
                                <TextBlock Grid.Row="5" Grid.Column="0" Text="GSM-nummer:" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="#334155" Margin="0,0,0,12"/>
                                <TextBox Grid.Row="5" Grid.Column="1" x:Name="txtGsm" Padding="8" FontSize="14" Margin="0,0,0,12" BorderThickness="1" BorderBrush="#CBD5E1">
                                    <TextBox.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="4"/>
                                        </Style>
                                    </TextBox.Resources>
                                </TextBox>

                                <!-- Notificaties -->
                                <TextBlock Grid.Row="6" Grid.Column="0" Text="Notificaties:" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="#334155" Margin="0,0,0,12"/>
                                <ComboBox Grid.Row="6" Grid.Column="1" x:Name="cmbNotificaties" Padding="8" FontSize="14" Margin="0,0,0,12" BorderThickness="1" BorderBrush="#CBD5E1">
                                    <ComboBoxItem Content="Geen"/>
                                    <ComboBoxItem Content="E-mail"/>
                                    <ComboBoxItem Content="Sms"/>
                                    <ComboBoxItem Content="Beide (E-mail &amp; Sms)"/>
                                </ComboBox>

                                <!-- Wachtwoord wijzigen -->
                                <TextBlock Grid.Row="7" Grid.Column="0" Text="Nieuw Wachtwoord:" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="#334155" Margin="0,0,0,20"/>
                                <TextBox Grid.Row="7" Grid.Column="1" x:Name="txtWachtwoord" Padding="8" FontSize="14" Margin="0,0,0,20" BorderThickness="1" BorderBrush="#CBD5E1">
                                    <TextBox.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="4"/>
                                        </Style>
                                    </TextBox.Resources>
                                </TextBox>
                            </Grid>

                            <!-- Opslaan en feedback meldingen -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <TextBlock Grid.Column="0" 
                                           x:Name="lblFoutmelding" 
                                           Foreground="#E74C3C" 
                                           FontWeight="Bold" 
                                           VerticalAlignment="Center" 
                                           TextWrapping="Wrap"/>
                                
                                <Button Grid.Column="1" 
                                        x:Name="btnOpslaan" 
                                        Content="Gegevens Opslaan" 
                                        Padding="20,10" 
                                        Background="#2ECC71" 
                                        Foreground="White" 
                                        FontWeight="Bold" 
                                        FontSize="15"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        Click="BtnOpslaan_Click">
                                    <Button.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="6"/>
                                        </Style>
                                    </Button.Resources>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
