<Page x:Class="WPFPatiënt.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="800"
      Title="Inloggen - Patiëntenportaal">

    <Grid Background="#F5F7FA">
        <Border Background="White"
                CornerRadius="12"
                Padding="30"
                Width="360"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                BorderBrush="#E2E8F0"
                BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" Color="#CBD5E1" Direction="270" ShadowDepth="3" Opacity="0.5"/>
            </Border.Effect>
            
            <StackPanel>
                <TextBlock Text="Mijn Portaal" 
                           FontSize="28" 
                           FontWeight="Bold" 
                           Foreground="#1F3B5B" 
                           HorizontalAlignment="Center" 
                           Margin="0,0,0,10"/>
                
                <TextBlock Text="Log in om uw afspraken te beheren" 
                           FontSize="13" 
                           Foreground="#64748B" 
                           HorizontalAlignment="Center" 
                           Margin="0,0,0,30"
                           TextAlignment="Center"/>

                <TextBlock Text="E-mailadres" 
                           FontWeight="SemiBold"  
                           Foreground="#334155" 
                           Margin="0,0,0,6"
                           FontSize="14"/>
                <TextBox x:Name="txtEmail" 
                         Padding="10" 
                         Margin="0,0,0,18" 
                         FontSize="14"
                         BorderThickness="1"
                         BorderBrush="#CBD5E1"
                         Text="sarwar@patient.be">
                    <TextBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>

                <TextBlock Text="Wachtwoord" 
                           FontWeight="SemiBold" 
                           Foreground="#334155" 
                           Margin="0,0,0,6"
                           FontSize="14"/>
                <PasswordBox x:Name="pwdWachtwoord" 
                             Padding="10" 
                             Margin="0,0,0,25" 
                             FontSize="14"
                             BorderThickness="1"
                             BorderBrush="#CBD5E1"
                             Password="t9ZmRrAbSfCvk">
                    <PasswordBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </PasswordBox.Resources>
                </PasswordBox>

                <Button x:Name="btnLogin" 
                        Content="Inloggen" 
                        Background="#3498DB" 
                        Foreground="White" 
                        FontWeight="Bold" 
                        FontSize="16" 
                        Padding="12" 
                        Cursor="Hand"
                        Click="BtnLogin_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <TextBlock x:Name="lblFoutmelding" 
                           Foreground="#E74C3C" 
                           HorizontalAlignment="Center" 
                           Margin="0,15,0,0" 
                           TextWrapping="Wrap" 
                           FontWeight="SemiBold"
                           FontSize="13"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
