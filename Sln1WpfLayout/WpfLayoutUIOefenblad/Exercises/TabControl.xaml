<Page x:Class="WpfLayoutUIOefenblad.Exercises.TabControl"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfLayoutUIOefenblad.Exercises"
      mc:Ignorable="d" 
      d:DesignHeight="650" d:DesignWidth="800"
      Title="TabControl">

    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="250px"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Frame x:Name="fraAssignment" Grid.Row="0" Grid.Column="0" Background="#eeeeee" />
        <Border Background="#EEFDEF" BorderBrush="#6B6CB0" BorderThickness="1" Padding="12" Margin="20" Grid.Row="1">
            <!-- TODO: PAS HIERONDER DE XAML AAN -->
            <TabControl>
                <TabItem Header="Account">
                    <Grid Margin="10">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Label Content="E-mail:" Grid.Row="0" Grid.Column="0" Margin="0,0,10,10"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Margin="0,0,0,10"/>

                        <Label Content="Wachtwoord:" Grid.Row="1" Grid.Column="0" Margin="0,0,10,10"/>
                        <PasswordBox Grid.Row="1" Grid.Column="1" Margin="0,0,0,10"/>

                        <Button Content="Wijzigen" Grid.Row="2" Grid.Column="1" HorizontalAlignment="Right" Width="70" Height="20" Margin="0,0,0,190"/>
                    </Grid>
                </TabItem>

                <TabItem Header="Voorkeuren">
                    <StackPanel Margin="10">
                        <CheckBox Content="Nieuwsbrief ontavangen" Margin="0,0,0,10"/>
                        <CheckBox Content="Donkere modus" Margin="0,0,0,10"/>
                        <CheckBox Content="Mledingen toetstaan"/>
                    </StackPanel>
                    
                </TabItem>

                <TabItem Header="Over">
                    <TextBlock Margin="10" TextWrapping="Wrap">
                        Dit is een voorbeeldaplicatie om Tabcontrol te oefenen. 
                        Gebruik tabs om instelingen 
                        <Run FontWeight="Bold"> Logisch te groeperen</Run>
                        en het scherm overzichteleijk te houden.
                        
                        <LineBreak/>
                        <LineBreak/>
                        <LineBreak/>
                        
                        Safi Harare, 2026.
                    </TextBlock>

                    
                </TabItem>
            </TabControl>
        </Border>
    </Grid>
</Page>
