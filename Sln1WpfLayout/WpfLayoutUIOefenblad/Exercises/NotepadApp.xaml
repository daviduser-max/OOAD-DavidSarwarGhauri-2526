<Page x:Class="WpfLayoutUIOefenblad.Exercises.NotepadApp"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfLayoutUIOefenblad.Exercises"
      mc:Ignorable="d" 
      d:DesignHeight="650" d:DesignWidth="800"
      Title="NotepadApp">

    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="250px"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Frame x:Name="fraAssignment" Grid.Row="0" Grid.Column="0" Background="#eeeeee" />
        <Border Background="White" BorderBrush="#6B6CB0" BorderThickness="1" Grid.Row="1" Margin="10" Height="200" Width="600">
            <!-- TODO: PAS HIERONDER DE XAML AAN -->
            <DockPanel LastChildFill="True">
                <Menu DockPanel.Dock="Top">
                    <MenuItem Header="File">
                        <MenuItem Header="New"/>
                        <MenuItem Header="Open..."/>
                        <MenuItem Header="Save"/>
                        <Separator/>
                        <MenuItem Header="Exit"/>
                    </MenuItem>

                    <MenuItem Header="Help">
                        <MenuItem Header="Check for updates"/>
                            <MenuItem Header="About" Click="About_Click"/>
                        </MenuItem>
                   
                </Menu>

                <StatusBar DockPanel.Dock="Bottom">
                    <StatusBarItem>
                        <TextBlock Text="Bestand: Tekst.txt"/>
                    </StatusBarItem>

                    <StatusBarItem HorizontalAlignment="Stretch"/>
                    <StatusBarItem>
                        <TextBlock Text="encoding: utf-8"/>
                    </StatusBarItem>
                    
                    
                    

                </StatusBar>
                        
                 <TabControl SelectionChanged="TabControl_SelectionChanged">
                     <TabItem Header="Tekst.txt">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <TextBox Text="Hier staat tekst 1"  AcceptsReturn="True" TextWrapping="Wrap"/>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="Untitled.txt">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                   <TextBox Text="Hier staat tekst 1" AcceptsReturn="True" TextWrapping="Wrap"/>
                               </ScrollViewer>
                    </TabItem>
                </TabControl>
                     
                     
                   
            </DockPanel>
        </Border>
    </Grid>
</Page>
