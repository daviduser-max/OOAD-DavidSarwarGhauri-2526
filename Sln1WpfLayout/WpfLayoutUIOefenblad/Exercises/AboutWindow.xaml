<Window x:Class="WpfLayoutUIOefenblad.Exercises.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfLayoutUIOefenblad.Exercises"
        mc:Ignorable="d"
        Title="AboutWindow" Height="450" Width="800">
    <Grid>
        <StackPanel Margin ="20">
            <TextBlock Text="WPF NotePad 1.0" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>
            <TextBlock Text="Ontwikkeld door Safi Harare. Alle rechten voorbehouden" TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,30"/>
            <Button Content="Close" Width="100" HorizontalAlignment="Right" Click="Close_Click"/>




        </StackPanel>
    </Grid>
    
</Window>
